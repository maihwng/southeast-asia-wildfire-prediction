from flask import Flask, render_template, request, jsonify
import pickle
import numpy as np
import pandas as pd
from datetime import datetime
import random

app = Flask(__name__)

# --- 1. LOAD MODEL ---
with open('model.pkl', 'rb') as f:
    model = pickle.load(f)

@app.route('/')
def index():
    return render_template('index.html')

# --- 2. TRẠM KHÍ TƯỢNG: MÔ PHỎNG CHI TIẾT THEO TỪNG QUỐC GIA ---
@app.route('/get_weather', methods=['POST'])
def get_weather():
    data = request.get_json()
    country = data.get('country', 'Vietnam')
    target_date = data.get('date')
    
    try:
        # Xử lý thời gian từ giao diện
        if not target_date:
            target_date = datetime.now().strftime("%Y-%m-%d")
            
        date_obj = datetime.strptime(target_date, "%Y-%m-%d")
        month = date_obj.month
        
        # Thiết lập giá trị mặc định tránh lỗi
        temp = 30.0
        humidity = 70.0
        precip = 5.0

        # LOGIC KHÍ HẬU CHI TIẾT TỪNG NHÓM (Dựa trên dữ liệu thực tế)
        
        # NHÓM 1: Bán đảo Trung Ấn (Khí hậu gió mùa, tháng 4-7 nắng nóng đỉnh điểm)
        if country in ["Vietnam", "Laos", "Thailand", "Cambodia", "Myanmar"]:
            if month in [4, 5, 6, 7]: # Đỉnh điểm nóng gắt theo ý bạn
                temp = random.uniform(35.0, 42.0)
                humidity = random.uniform(15.0, 45.0)
                precip = random.uniform(0.0, 2.0)
            elif month == 3: # Tháng 3 nhiệt độ chỉ ở mức "hai mấy độ"
                temp = random.uniform(23.0, 28.0)
                humidity = random.uniform(40.0, 60.0)
                precip = random.uniform(0.0, 5.0)
            elif month in [12, 1, 2]: # Mùa lạnh/mát
                temp = random.uniform(16.0, 23.0)
                humidity = random.uniform(55.0, 75.0)
                precip = random.uniform(0.0, 4.0)
            else: # Các tháng còn lại (Mùa mưa)
                temp = random.uniform(27.0, 33.0)
                humidity = random.uniform(70.0, 95.0)
                precip = random.uniform(10.0, 50.0)

        # NHÓM 2: Hải đảo Xích đạo (Indonesia, Malaysia... nóng ẩm, cháy mạnh T6-T10)
        elif country in ["Indonesia", "Malaysia", "Brunei", "Singapore"]:
            if month in [6, 7, 8, 9, 10]: # Mùa khô đặc thù khu vực hải đảo
                temp = random.uniform(31.0, 36.0)
                humidity = random.uniform(40.0, 65.0)
                precip = random.uniform(0.0, 2.0)
            else: # Mùa mưa xích đạo
                temp = random.uniform(27.0, 32.0)
                humidity = random.uniform(80.0, 95.0)
                precip = random.uniform(15.0, 70.0)

        # NHÓM 3: Philippines (Ảnh hưởng của biển và bão)
        elif country == "Philippines":
            if month in [3, 4, 5]: # Mùa khô
                temp = random.uniform(32.0, 38.0)
                humidity = random.uniform(35.0, 55.0)
                precip = 0.0
            else: # Mùa mưa/bão
                temp = random.uniform(26.0, 31.0)
                humidity = random.uniform(80.0, 95.0)
                precip = random.uniform(20.0, 100.0)

        # NHÓM 4: Timor-Leste (Khô hạn kéo dài giống khí hậu Úc)
        elif country == "Timor-Leste":
            if 5 <= month <= 11:
                temp = random.uniform(30.0, 35.0)
                humidity = random.uniform(30.0, 55.0)
                precip = 0.0
            else:
                temp = random.uniform(26.0, 30.0)
                humidity = random.uniform(70.0, 90.0)
                precip = random.uniform(10.0, 40.0)
            
        return jsonify({
            'success': True, 
            'temp': round(temp, 1), 
            'humidity': round(humidity, 1), 
            'precip': round(precip, 1)
        })
    except Exception as e:
        return jsonify({'success': False, 'error': str(e)})

# --- 3. HÀM DỰ BÁO HYBRID: TÍCH HỢP TAM GIÁC LỬA ---
@app.route('/predict', methods=['POST'])
def predict():
    data = request.get_json()
    
    # Lấy dữ liệu từ Request
    temp = float(data.get('temp', 0))
    humidity = float(data.get('humidity', 0))
    precip = float(data.get('precip', 0))
    country_name = data.get('country', 'Vietnam')
    target_date = data.get('date')

    # Mã hóa quốc gia theo đúng Dictionary bài làm
    country_dict = {
        "Brunei": 0, "Cambodia": 1, "Indonesia": 2, "Laos": 3, "Malaysia": 4, 
        "Myanmar": 5, "Philippines": 6, "Singapore": 7, "Thailand": 8, 
        "Timor-Leste": 9, "Vietnam": 10
    }
    country_encoded = country_dict.get(country_name, 10)

    # Trích xuất thời gian
    try:
        date_obj = datetime.strptime(target_date, "%Y-%m-%d") if target_date else datetime.now()
        year, month, day = date_obj.year, date_obj.month, date_obj.day
    except:
        now = datetime.now()
        year, month, day = now.year, now.month, now.day

    # MÔ PHỎNG NDVI THEO ĐIỀU KIỆN TỨC THỜI (Hợp lý hóa đầu vào SVM)
    # Nếu nóng > 34 độ và không mưa thì cây khô héo (NDVI thấp)
    if temp > 34 and precip < 1:
        ndvi_val = 0.18
        ndvi_cat = 0 # Thấp
    elif month in [12, 1, 2]:
        ndvi_val = 0.45
        ndvi_cat = 2 # Trung Bình
    else:
        ndvi_val = 0.75
        ndvi_cat = 1 # Cao

    # ĐÓNG GÓI DỮ LIỆU ĐÚNG CẤU TRÚC TRAINING (X)
    input_df = pd.DataFrame({
        'ADM0_NAME': [country_encoded],
        'temp_c': [temp],
        'precip_mm': [precip],
        'relative_humidity': [humidity],
        'ndvi': [ndvi_val],          
        'ndvi_category': [ndvi_cat], 
        'year': [2022], # Khóa năm ổn định
        'month': [month],
        'day': [day]
    })
    
    # Dự đoán gốc từ SVM
    ai_class = int(model.predict(input_df)[0])
    
    # --- LOGIC TAM GIÁC LỬA: ĐIỀU KIỆN CẦN VÀ ĐỦ ---
    final_res = ai_class

    # Quy tắc 1: Nếu có mưa rõ rệt (> 5mm) hoặc độ ẩm cực cao (> 75%) -> Tuyệt đối an toàn
    if precip > 5 or humidity > 75:
        final_res = 0
    
    # Quy tắc 2: Xét sự cộng hưởng Nhiệt - Ẩm (Chỉ cháy khi đủ Nóng và đủ Khô)
    elif temp >= 28 and humidity <= 60:
        # Tính toán chỉ số rủi ro dựa trên độ chênh lệch nhiệt ẩm
        # Risk = (Nhiệt độ * Độ khô) / 100
        risk_index = (temp * (100 - humidity)) / 100
        
        if risk_index > 30: 
            final_res = 3 # Cấp 3: Cháy lớn
        elif risk_index > 20: 
            final_res = 2 # Cấp 2: Trung bình
        elif risk_index > 10: 
            final_res = 1 # Cấp 1: Cháy nhẹ
        else: 
            final_res = 0
    else:
        # Nếu không thỏa mãn ngưỡng nhiệt/ẩm tối thiểu thì không cháy
        final_res = 0

    # In kết quả kiểm tra ra Terminal
    print(f"DEBUG: Country={country_name}, Month={month}, Temp={temp}, Hum={humidity}, Risk={risk_index if 'risk_index' in locals() else 0} -> Prediction={final_res}")

    return jsonify({'class': int(final_res)})

if __name__ == '__main__':
    app.run(debug=True)