   "source": [
    "# 1. LỖI KHUYẾT THIẾU (MISSING DATA)\n",
    "print(\"1. LỖI KHUYẾT THIẾU DỮ LIỆU (NaN)\")\n",
    "missing_data = df.isnull().sum()\n",
    "missing_data = missing_data[missing_data > 0].sort_values(ascending=False)\n",
    "if not missing_data.empty:\n",
    "    for col, count in missing_data.items():\n",
    "        percentage = (count / df.shape[0]) * 100\n",
    "        print(f\"   - Cột '{col}': Trống {count} dòng ({percentage:.2f}%)\")\n",
    "else:\n",
    "    print(\"Không có dữ liệu khuyết thiếu.\")\n",
    "\n",
    "# 2. LỖI NGOẠI LAI (OUTLIERS)\n",
    "print(\"\\n2. LỖI NGOẠI LAI (OUTLIERS & NHIỄU VẬT LÝ)\")\n",
    "numerical_cols = ['temp_c', 'precip_mm', 'relative_humidity', 'ndvi', 'fire_count']\n",
    "stats = df[numerical_cols].describe().T\n",
    "print(stats[['min', 'max', 'mean', '50%']].to_string())\n",
    "\n",
    "print(\"\\n   [Phân tích tự động các điểm bất thường]:\")\n",
    "if df['temp_c'].max() > 60 or df['temp_c'].min() < -10:\n",
    "    print(f\"Nhiệt độ có giá trị phi lý: Min = {df['temp_c'].min()}°C, Max = {df['temp_c'].max()}°C\")\n",
    "if df['relative_humidity'].max() > 100 or df['relative_humidity'].min() < 0:\n",
    "    print(f\"Độ ẩm vượt giới hạn tự nhiên [0-100%]: Min = {df['relative_humidity'].min()}%, Max = {df['relative_humidity'].max()}%\")\n",
    "if df['fire_count'].min() < 0:\n",
    "    print(f\"Số vụ cháy bị âm: Min = {df['fire_count'].min()} vụ\")\n",
    "\n",
    "# 3. LỖI KHÔNG NHẤT QUÁN (INCONSISTENT DATA)\n",
    "print(\"\\n3. LỖI DỮ LIỆU KHÔNG NHẤT QUÁN\")\n",
    "\n",
    "# --- Bắt đầu phần kiểm tra ngày tháng nâng cấp ---\n",
    "df['date_parsed'] = pd.to_datetime(df['date'], errors='coerce')\n",
    "failed_dates = df[df['date_parsed'].isnull()]['date'].dropna()\n",
    "\n",
    "if len(failed_dates) > 0:\n",
    "    unique_invalid = failed_dates.unique()\n",
    "    print(f\"- Cột 'date': Phát hiện {len(failed_dates)} dòng bị lỗi định dạng ngày tháng.\")\n",
    "    print(f\"  -> Có {len(unique_invalid)} kiểu giá trị lỗi khác nhau (Ví dụ: lịch Julian, ngày ảo, chữ rác).\")\n",
    "    print(f\"  -> Các giá trị lỗi tiêu biểu (Top 20):\")\n",
    "    for val in unique_invalid[:20]:\n",
    "        print(f\"     * '{val}'\")\n",
    "else:\n",
    "    print(\"- Cột 'date': 100% ngày tháng hợp lệ, không có lỗi.\")\n",
    "# --- Kết thúc phần kiểm tra ngày tháng ---\n",
    "\n",
    "countries = df['ADM0_NAME'].dropna().unique()\n",
    "print(f\"\\n- Cột 'ADM0_NAME': Số lượng nhãn Quốc gia đang có (Chưa chuẩn hóa): {len(countries)}\")\n",
    "print(f\"  Danh sách các biến thể đang tồn tại:\")\n",
    "print(f\"  {countries}\")\n",
    "\n",
    "# 4. LỖI TRÙNG LẶP DỮ LIỆU (DUPLICATED DATA)\n",
    "print(\"\\n4. LỖI TRÙNG LẶP DỮ LIỆU\")\n",
    "duplicate_count = df.duplicated().sum()\n",
    "if duplicate_count > 0:\n",
    "    dup_percentage = (duplicate_count / df.shape[0]) * 100\n",
    "    print(f\"Phát hiện {duplicate_count} dòng bị trùng lặp hoàn toàn ({dup_percentage:.2f}%).\")\n",
    "else:\n",
    "    print(\"Không có dữ liệu trùng lặp hoàn toàn.\")\n",
    "\n",
    "print(\"=\"*60)"
