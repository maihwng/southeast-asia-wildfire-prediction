   ],
   "source": [
    "# Rời rạc hóa (Discretization/Binning) số vụ cháy thành 4 cấp độ\n",
    "# Hàm phân loại cập nhật\n",
    "def categorize_severity(count):\n",
    "    # Chốt chặn 2: Nếu có giá trị NaN lọt lưới, tự động xếp vào Không cháy\n",
    "    if pd.isna(count): return 0  \n",
    "    elif count == 0: return 0      # Không cháy\n",
    "    elif count <= 5: return 1      # Cháy nhẹ\n",
    "    elif count <= 20: return 2     # Cháy trung bình\n",
    "    else: return 3                 # Cháy lớn\n",
    "\n",
    "df['fire_severity'] = df['fire_count'].apply(categorize_severity)\n",
    "\n",
    "print(\"Phân bố mức độ cháy (Fire Severity):\")\n",
    "print(df['fire_severity'].value_counts().sort_index())\n",
    "# giảm nhiễu, chuyển bài toán sang dạng phân lớp và chuẩn bị cho bước smote"
   ]
  },
