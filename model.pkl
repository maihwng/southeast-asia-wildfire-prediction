    "# Binning NDVI\n",
    "df['ndvi_category'] = pd.cut(df['ndvi'], bins=[-1, 0.2, 0.5, 1.0], labels=['Thap', 'Trung_Binh', 'Cao'])\n",
    "\n",
    "# Label Encoding\n",
    "encoder = LabelEncoder()\n",
    "for col in ['ADM0_NAME', 'ndvi_category']:\n",
    "    df[col] = encoder.fit_transform(df[col].astype(str)) "
   ]
