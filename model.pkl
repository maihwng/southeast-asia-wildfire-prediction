  {
   "cell_type": "markdown",
   "id": "417a39e1",
   "metadata": {},
   "source": [
    "Xóa dữ liệu trùng lặp và Chuẩn hóa định dạng"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "46854119",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Đã sửa thành công định dạng ngày tháng Julian (YYYY-MM-JJJ) từ GEE!\n",
      "Phát hiện 0 dòng ngày tháng bị rác/ảo hoàn toàn (đã chuyển thành NaT).\n"
     ]
    }
   ],
   "source": [
    "def fix_all_dates(date_str):\n",
    "    if pd.isna(date_str): \n",
    "        return date_str\n",
    "    \n",
    "    # Xóa khoảng trắng và cắt bỏ phần giờ\n",
    "    date_str = str(date_str).strip().split()[0] \n",
    "\n",
    "    if date_str.lower() in ['unknown', 'nan', '0', 'missing', 'none']:\n",
    "        return pd.NaT\n",
    "\n",
    "    parts = date_str.split('-')\n",
    "    \n",
    "    if len(parts) == 3:\n",
    "        year = parts[0]\n",
    "        month = parts[1]\n",
    "        julian_day = parts[2]\n",
    "        \n",
    "        if julian_day.isdigit() and len(year) == 4 and 1 <= int(julian_day) <= 366:\n",
    "            parsed_julian = pd.to_datetime(year + julian_day, format='%Y%j', errors='coerce')\n",
    "\n",
    "            if pd.notnull(parsed_julian) and parsed_julian.month == int(month):\n",
    "                return parsed_julian\n",
    "            \n",
    "    return pd.to_datetime(date_str, format='mixed', errors='coerce')\n",
    "\n",
    "# 2. ÁP DỤNG HÀM VÀO CỘT DATE\n",
    "df['date'] = df['date'].apply(fix_all_dates)\n",
    "\n",
    "# 3. DỌN DẸP VÀ THỐNG KÊ \n",
    "df = df.drop(columns=['date_parsed'], errors='ignore')\n",
    "\n",
    "# Đếm xem có bao nhiêu ngày rác đã bị biến thành NaT\n",
    "so_dong_loi = df['date'].isna().sum()\n",
    "\n",
    "print(f\"Đã sửa thành công định dạng ngày tháng Julian (YYYY-MM-JJJ) từ GEE!\")\n",
    "print(f\"Phát hiện {so_dong_loi} dòng ngày tháng bị rác/ảo hoàn toàn (đã chuyển thành NaT).\")"
   ]
  },
