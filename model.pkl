    "# Boxplot phát hiện Outlier (Dùng math.ceil tự động chia khung)\n",
    "num_cols_len = len(numerical_columns)\n",
    "num_rows = math.ceil(num_cols_len / 3)\n",
    "\n",
    "plt.figure(figsize=(15, num_rows * 4))\n",
    "for idx, col in enumerate(numerical_columns, 1):\n",
    "    plt.subplot(num_rows, 3, idx)\n",
    "    sns.boxplot(y=df[col], color='skyblue')\n",
    "    plt.title(f'Boxplot of {col}')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "910462ca",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Xử lý Outlier bằng IQR (Chỉ áp dụng cho thời tiết, giữ nguyên tín hiệu cháy)\n",
    "def cap_outliers_iqr(df, col):\n",
    "    Q1 = df[col].quantile(0.25)\n",
    "    Q3 = df[col].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lower, upper = Q1 - 1.5 * IQR, Q3 + 1.5 * IQR\n",
    "    \n",
    "    df[col] = np.where(df[col] > upper, upper, df[col])\n",
    "    df[col] = np.where(df[col] < lower, lower, df[col])\n",
    "    return df\n",
    "\n",
    "for col in ['temp_c', 'precip_mm', 'relative_humidity']:\n",
    "    df = cap_outliers_iqr(df, col)"
   ]
  },
