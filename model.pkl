    "def clean_country_name(name):\n",
    "    name = str(name).lower() \n",
    "    if 'bru' in name or 'burma' in name: return 'Brunei'\n",
    "    if 'cam' in name: return 'Cambodia'\n",
    "    if 'indo' in name: return 'Indonesia'\n",
    "    if 'lao' in name: return 'Laos'\n",
    "    if 'malay' in name: return 'Malaysia'\n",
    "    if 'myan' in name: return 'Myanmar'\n",
    "    if 'phil' in name: return 'Philippines'\n",
    "    if 'sing' in name: return 'Singapore'\n",
    "    if 'thai' in name: return 'Thailand'\n",
    "    if 'timor' in name: return 'Timor-Leste'\n",
    "    if 'viet' in name or 'vn' in name: return 'Vietnam'\n",
    "    return name\n",
    "\n",
    "# Chỉ cần 1 dòng lệnh apply để áp dụng hàm lên toàn bộ cột\n",
    "df['ADM0_NAME'] = df['ADM0_NAME'].apply(clean_country_name)\n",
    "\n",
    "print(f\"Số lượng quốc gia chuẩn: {df['ADM0_NAME'].nunique()}\")\n",
    "print(\"Danh sách:\", df['ADM0_NAME'].unique())"
   ]
